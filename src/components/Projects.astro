---
import { useTranslation } from "@/i18n";
import { PROJECTS_DATA, type TechnologyId } from "@/data/portfolio";
import ProjectItem from "@components/ProjectItem.astro";

import AWSIcon from "@icons/Aws.astro";
import ExpressIcon from "@icons/Express.astro";
import GraphQLIcon from "@icons/GraphQL.astro";
import MySQLIcon from "@icons/MySql.astro";
import NodeJSIcon from "@icons/NodeJS.astro";
import PrismaIcon from "@icons/Prisma.astro";
import TypescriptIcon from "@icons/Typescript.astro";
import VueIcon from "@icons/Vue.astro";

const { currentLocale } = Astro;
const { t } = useTranslation(currentLocale);
const locale = currentLocale === "en" ? "en" : "es";

const TECHNOLOGIES: Record<
  TechnologyId,
  {
    name: string;
    class: string;
    icon: any;
  }
> = {
  aws: {
    name: "AWS",
    class:
      "bg-[#FFF6E8] text-[#744600] dark:bg-[#FF990035] dark:text-[#FF9900]",
    icon: AWSIcon,
  },
  express: {
    name: "Express",
    class:
      "bg-[#F0F2F2] text-[#43494C] dark:bg-[#E4E7E835] dark:text-[#E4E7E8]",
    icon: ExpressIcon,
  },
  graphql: {
    name: "GraphQL",
    class:
      "bg-[#FCE8F6] text-[#90026A] dark:bg-[#F18BD035] dark:text-[#F18BD0]",
    icon: GraphQLIcon,
  },
  mysql: {
    name: "MySQL",
    class:
      "bg-[#E8F2F5] text-[#005568] dark:bg-[#74B4C235] dark:text-[#74B4C2]",
    icon: MySQLIcon,
  },
  node: {
    name: "Node.js",
    class:
      "bg-[#E4F4DE] text-[#215732] dark:bg-[#6cc24a35] dark:text-[#6cc24a]", // #333333
    icon: NodeJSIcon,
  },
  prisma: {
    name: "Prisma",
    class: "bg-[#EAEBEC] text-[#0C344B] dark:bg-[#071F33] dark:text-white",
    icon: PrismaIcon,
  },
  typescript: {
    name: "TypeScript",
    class:
      "bg-[#ECF3FA] text-[#1F4C7E] dark:bg-[#8FB5E035] dark:text-[#8FB5E0]",
    icon: TypescriptIcon,
  },
  vue: {
    name: "Vue.js",
    class:
      "bg-[#EEF9F4] text-[#35495e] dark:bg-[#42b88335] dark:text-[#42b883]",
    icon: VueIcon,
  },
};

const projects = PROJECTS_DATA.map((project) => ({
  ...project,
  ...project.content[locale],
  technologies: project.technologies.map(
    (technology) => TECHNOLOGIES[technology],
  ),
  visitWebsiteLabel: t("projects.visitWebsite"),
}));
---

<ul class="mt-16 space-y-24">
  {
    projects.map((project, index) => (
      <li>
        <ProjectItem {...project} reverse={index % 2 === 1} />
      </li>
    ))
  }
</ul>
